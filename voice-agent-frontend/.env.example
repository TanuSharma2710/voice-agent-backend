# Supabase (required)
# Get from: Supabase Dashboard > Settings > API > Project URL
# The publishable key starts with "sb_publishable_" - it's PUBLIC and safe to expose
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Backend API URL (required)
VITE_API_URL=http://localhost:8000/api
# Or for production:
# VITE_API_URL=https://your-api-domain.com/api

# Backend WebSocket URL for voice agent (required)
VITE_WS_URL=ws://localhost:8000/api/voice
# Or for production:
# VITE_WS_URL=wss://your-api-domain.com/api/voice