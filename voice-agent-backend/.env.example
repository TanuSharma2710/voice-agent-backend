# =============================================================================
# SECRETS ONLY - API keys and sensitive values
# =============================================================================
# (All other settings are in config.py)

# Supabase (required for auth)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Direct PostgreSQL connection (required for database persistence + auto table creation)
# Find in: Supabase dashboard → Settings → Database → Connection string → URI
# Use the "Session mode" URI (port 5432), not the transaction pooler
DATABASE_URL=postgresql://postgres:[your-db-password]@db.[project-ref].supabase.co:5432/postgres

# Encryption key for database URLs
# Generate with: python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Groq API (required - get from https://console.groq.com)
GROQ_API_KEY=your-groq-api-key

# Gemini API (required - get from https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-google-gemini-api-key

# Qdrant Cloud (required - get from https://qdrant.to)
QDRANT_API_KEY=your-qdrant-api-key
QDRANT_ENDPOINT=https://your-qdrant-cloud.cloud.qdrant.io

# Deepgram API (optional - only if using voice feature)
DEEPGRAM_API_KEY=your-deepgram-api-key
